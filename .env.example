# ─── App ────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-railway-domain.up.railway.app
APP_URL=https://your-railway-domain.up.railway.app

# ─── Database (Railway PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dtf_pipeline

# ─── Shopify App ────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_customers,write_customers,read_draft_orders,write_draft_orders,read_orders,write_orders
SHOPIFY_HOST_NAME=your-railway-domain.up.railway.app

# ─── Shopify Customer Account API (for buyer login) ─────────────────────────
SHOPIFY_CUSTOMER_AUTH_URL=https://shopify.com/{shop-id}
SHOPIFY_CUSTOMER_CLIENT_ID=your_customer_account_client_id
# Default shop ID used when shopId is not passed via query string
DEFAULT_SHOP_ID=your_default_shop_cuid

# ─── Customer Session ────────────────────────────────────────────────────────
# Random 32+ char secret for signing buyer session JWTs
CUSTOMER_SESSION_SECRET=change_me_to_a_random_secret_32_chars_min

# ─── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Webhook ─────────────────────────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret
